<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>เมนูอาหารแสนอร่อย</title>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #f4f7f6;
            padding: 20px;
        }

        h1 {
            text-align: center;
            color: #333;
        }

        /* 🌟 สร้าง Grid Layout */
        .grid-container {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
            gap: 20px;
            max-width: 1200px;
            margin: 0 auto;
        }

        /* 🌟 ตกแต่งการ์ดแต่ละใบ */
        .card {
            background-color: white;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
            transition: transform 0.3s;
        }

        .card:hover {
            transform: translateY(-5px);
            /* เอฟเฟกต์ยกการ์ดตอนเอาเมาส์ชี้ */
        }

        .card img {
            width: 100%;
            height: 200px;
            object-fit: cover;
            /* จัดรูปไม่ให้เบี้ยว */
        }

        .card-content {
            padding: 15px;
        }

        .price {
            color: #e74c3c;
            font-size: 1.2em;
            font-weight: bold;
            margin: 10px 0;
        }

        .desc {
            color: #666;
            font-size: 0.9em;
            line-height: 1.4;
        }
    </style>
</head>

<body>

    <h1>เมนูอาหารแนะนำ 🍽️</h1>

    <div class="grid-container">
        <% foods.forEach(item=> { %>
            <div class="card">
                <img src="<%= item.image %>" alt="<%= item.name %>">

                <div class="card-content">
                    <h2>
                        <%= item.name %>
                    </h2>

                    <div class="price">ราคา: <%= item.price %> บาท</div>

                    <p class="desc">
                        <%= item.description %>
                    </p>
                </div>
            </div>
            <% }); %>
    </div>

</body>

</html>